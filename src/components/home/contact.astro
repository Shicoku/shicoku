<div class="contact">
  <div class="message">
    <h1>お気軽にご相談ください。</h1>
    <p>相談、意見、リクエスト等、どんな内容でも歓迎します。</p>
    <p>
      匿名で送信したい方は、名前とメールアドレスを入力しなくても構いません。
    </p>
  </div>
  <div class="form">
    <div class="feedback-form">
      <form id="contactForm">
        <label for="name">お名前 (任意)</label>
        <input type="text" name="name" placeholder="お名前" />
        <label for="email">メールアドレス (任意)</label>
        <input type="email" name="email" placeholder="メールアドレス" />
        <label for="message">お問い合わせ内容 (必須)</label>
        <textarea name="message" placeholder="お問い合わせ内容" required
        ></textarea>
        <button type="submit" class="form-btn">送信</button>
      </form>
    </div>
  </div>
</div>

<style>
  div {
    display: flex;
    height: 100vh;
    justify-content: center;
  }

  .contact {
    margin-top: 80px;
  }

  .message {
    flex-direction: column;
    align-items: left;
    padding: 5rem;
    margin-top: -200px;
  }
  .message h1 {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  .message p {
    width: 500px;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .form {
    border: solid 5px #fff;
    border-radius: 15px;
    padding-right: 10rem;
    margin-left: -80px;
    margin-top: 70px;
    height: 60%;
  }
  .form::before {
    content: "Contact";
    font-size: 3rem;
    font-family: boldnese;
    margin-top: -60px;
    margin-left: 30px;
    background: #7ea3cc;
    padding: 0 5px;
  }

  #contactForm {
    max-width: 480px;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 50px;
    margin-left: -250px;
  }
  label {
    font-weight: bold;
  }
  #contactForm input,
  textarea {
    margin-top: -10px;
    width: 150%;
    padding: 0.5rem;
    font-size: 1rem;
    background: #ffffff00;
    border: 5px solid #ffffff;
    border-radius: 10px;
    outline: none;
    color: #fff;
  }
  textarea {
    height: 120px;
    resize: none;
  }
  .form-btn {
    padding: 0.5rem 1rem;
    width: 162%;
    font-size: 1.2rem;
    background: #497cb6;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-family: "kt";
    color: #fff;
  }

  @media screen and (max-width: 789px) {
    div {
      flex-direction: column;
    }

    .message {
      margin-top: 0;
    }
    .message h1 {
      font-size: 2rem;
    }
    .message p {
      width: 300px;
      font-size: 1.2rem;
    }

    .form {
      padding-right: 0rem;
      margin-left: 0px;
      height: 70%;
      margin-top: 0px;
    }
    .form::before {
      content: "Contact";
      margin-left: 30px;
      padding: 0 10px;
      width: 260px;
    }

    #contactForm {
      max-width: 350px;
      margin: 0 auto;
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 50px;
      margin-left: 10px;
    }

    #contactForm input,
    textarea {
      width: 130%;
    }
    .form-btn {
      width: 140%;
    }
  }
</style>

<script>
  const contactForm = document.getElementById("contactForm");
  if (contactForm) {
    contactForm.addEventListener("submit", async (e: Event) => {
      e.preventDefault();
      const formData = new FormData(e.target as HTMLFormElement);
      const data = Object.fromEntries(formData.entries());

      const res = await fetch("/api/feedback", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });

      if (res.ok) {
        alert("送信完了しました！");
      } else {
        alert("送信に失敗しました。");
      }
    });
  }
</script>
