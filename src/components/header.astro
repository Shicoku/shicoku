<header>
  <div class="logo">
    <h1><a href="/">Shicoku</a></h1>
  </div>
  <div>
    <div class="menu-bg"></div>
    <ul>
      <li class="pc"><a href="/about">About</a></li>
      <li class="pc"><a href="/projects">Projects</a></li>
      <li class="pc"><a href="/contact">Contact</a></li>
      <li>
        <input type="checkbox" id="menu-btn-check" />
        <label for="menu-btn-check" class="menu-btn"
          ><span class="menu"></span></label
        >
      </li>
    </ul>
  </div>
</header>

<div class="menu-overlay">
  <div class="menu-content">
    <div class="content">
      <a href="/about">About</a>
      <a href="/projects">Projects</a>
      <a href="/contact">Contact</a>
      <a href="/pages/credit">Credit</a>
      <!-- <a href="/pages/logo">Logo</a> -->
    </div>
  </div>
</div>

<style>
  header {
    position: fixed;
    width: 100%;
    height: 5rem;
    color: #fff;
    display: flex;
    z-index: 1000;
    top: 0;
    left: 0;
    backdrop-filter: blur(10px);
    background: rgba(73, 124, 182, 0);

    user-select: none;
    -moz-user-select: none;
    -webkit-user-select: none;
    -ms-user-select: none;
  }

  input[type="checkbox"] {
    display: none;
  }

  .logo h1 {
    position: fixed;
    top: 0;
    left: 0;
    margin: 0;
    padding: 0.5rem 1rem;
    font-size: 2rem;
    z-index: 1000;
  }
  .logo a {
    font-family: kt;
  }

  ul {
    position: fixed;
    margin: 0;
    padding: 0;
    right: 70px;
    top: 15px;
    font-size: 1.7rem;
  }

  li {
    list-style: none;
    display: inline-block;
    margin-left: 1rem;
  }
  a {
    color: #fff;
    text-decoration: none;
    font-family: boldnese;
  }
  a:hover {
    color: #ccc;
    text-decoration: underline;
  }

  li label {
    width: 30px;
    height: 30px;
    cursor: pointer;
    position: absolute;
    top: 26px;
  }

  .menu,
  .menu:before,
  .menu:after {
    content: "";
    display: block;
    height: 5px;
    width: 35px;
    border-radius: 3px;
    background-color: #fff;
    position: absolute;
    transition: all 0.3s ease;
  }
  .menu:before {
    bottom: 10px;
  }
  .menu:after {
    top: 10px;
  }

  #menu-btn-check:checked + label span {
    background-color: transparent;
  }
  #menu-btn-check:checked + label span:before {
    transform: rotate(45deg);
    bottom: 0;
  }
  #menu-btn-check:checked + label span:after {
    transform: rotate(-45deg);
    top: 0;
  }

  .active {
    color: #497cb6;
  }

  .menu-content {
    display: none;
    position: absolute;
    top: 60px;
    right: 10px;
    padding: 1rem;
    border-radius: 5px;
    flex-direction: column;
    gap: 0.5rem;
  }

  .content a {
    display: block;
    color: #fff;
    text-decoration: none;
    padding: 0.5rem 0;
    font-family: boldnese;
  }
  .content a:hover {
    color: #ccc;
    text-decoration: underline;
  }

  #menu-btn-check:checked ~ .menu-content {
    display: flex;
  }

  .menu-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #2c4a6d;
    z-index: 999;
    transform: translateY(-100%);
    transition: transform 0.3s ease-in-out;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .menu-overlay .menu-content {
    position: static;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    opacity: 0;
    transition: opacity 0.2s ease-in-out 0.3s;
  }

  .menu-overlay .menu-content.fade-in {
    opacity: 1;
  }

  .menu-overlay .content a {
    font-size: 2rem;
    padding: 1rem 0;
    z-index: 10;
  }

  .smart {
    display: none;
  }

  .pc {
    opacity: 1;
    transition: opacity 0.3s ease;
  }
  header.menu-open .pc {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 789px) {
    li label {
      top: 10px;
    }

    .pc {
      display: none;
    }
    .smart {
      display: block;
    }

    .menu-content > div {
      align-items: flex-start;
    }
  }
</style>

<script>
  import { projects as pj } from "../data/projects";
  const slugs = pj.map((p) => "/projects/" + p.slug);

  const about = document.querySelectorAll('a[href="/about"]');
  const projects = document.querySelectorAll('a[href="/projects"]');
  const contact = document.querySelectorAll('a[href="/contact"]');
  const menuBtnCheck = document.getElementById(
    "menu-btn-check",
  ) as HTMLInputElement;
  const menuOverlay = document.querySelector(".menu-overlay") as HTMLElement;
  const header = document.querySelector("header");

  window.addEventListener("DOMContentLoaded", () => {
    const currentPath = window.location.pathname;

    if (currentPath === "/about") {
      about.forEach((link) => link.classList.add("active"));
    } else if (currentPath === "/projects" || slugs.includes(currentPath)) {
      projects.forEach((link) => link.classList.add("active"));
    } else if (currentPath === "/contact") {
      contact.forEach((link) => link.classList.add("active"));
    }

    if (menuBtnCheck && menuOverlay) {
      const menuContent = menuOverlay.querySelector(
        ".menu-content",
      ) as HTMLElement;
      menuBtnCheck.addEventListener("change", () => {
        if (menuBtnCheck.checked) {
          menuOverlay.style.transform = "translateY(0)";
          header?.classList.add("menu-open");
          setTimeout(() => {
            menuContent.classList.add("fade-in");
          }, 300);
        } else {
          menuOverlay.style.transform = "translateY(-100%)";
          menuContent.classList.remove("fade-in");
          header?.classList.remove("menu-open");
        }
      });
    }
  });
</script>
