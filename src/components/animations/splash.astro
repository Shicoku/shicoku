---

<div id="splash">
  <div class="logo">
    <img src="/icons/logo.svg" alt="Shicoku Logo" />
  </div>
</div>

<style>
  #splash {
    position: fixed;
    inset: 0;
    background: #497cb6;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    transition: opacity 0.6s ease;
  }

  .logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  #splash.hide {
    opacity: 0;
    pointer-events: none;
  }

  .logo img {
    width: 25%;
    height: auto;
    min-width: 150px;
    max-width: 300px;
    display: block;
    object-fit: contain;
    opacity: 0;
    animation: logoFadeIn 1.5s ease-out forwards;
    animation-delay: 0.3s;
  }
  @keyframes logoFadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script>
  window.addEventListener("load", () => {
    const splash = document.getElementById("splash");
    setTimeout(() => {
      splash?.classList.add("hide");
    }, 1500);
  });
</script>
